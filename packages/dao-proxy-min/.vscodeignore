# v9.4.1 · 大道至简 · 唯留运行时必需
# ═══════════════════════════════════════════════
# 运行时必需保留: extension.js, package.json, media/, readme.md, LICENSE.txt, vendor/bundled-origin/source.js
# ═══════════════════════════════════════════════

# 标工 · 开发环境
.vscode/**
.vscode-test/**
out/**
node_modules/**
src/**
.gitignore
.eslintrc.json
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts

# 打包产物
*.vsix
.vsixmanifest

# v9.9.4 备份/损版不入包 (反者道之动 · 损版只留工作目录为戒)
*.bak
**/*.bak
*.v9.9.2-MN-bak
**/*.v9.9.2-MN-bak
# v9.9.21 · timestamp 后缀备份 (例 .vsix.bak_20260518_180850 / .vsix.bak_jiqi_only_xxx)
*.bak_*
**/*.bak_*
*.vsix.bak*
**/*.vsix.bak*

# v9.9.21 · 历史验证脚本 (verify_v9913.cjs 等) 不属运行时
verify_v*.cjs
**/verify_v*.cjs
verify_v*.js
**/verify_v*.js

# dev harness / 部署脚本 / 探针 / 日志 / 缓存 · 一律 _ 前缀 → 全排
_*
**/_*

# 散 log / 散 dump · 不以 _ 起首 (e.g. e2e_*.log)
*.log
**/*.log
*.dump.html
*.dump.json
*.dump.txt
**/*.dump.*

# 守保密 · 配文与凭证文件明排 (即便不带 _ 前缀)
_审视/_dao.env.json
**/_dao.env.json
**/dao-cred.xml
**/*.cred.xml

# 白名单 · 帛书《老子》二文是运行时本源 · 必入包
!vendor/bundled-origin/_silk_de.txt
!vendor/bundled-origin/_silk_dao.txt
# 经藏多门 · 五新经文 · 必入包 (v9.9.18 印126)
!vendor/bundled-origin/_yinfu.txt
!vendor/bundled-origin/_heraclitus.txt
!vendor/bundled-origin/_liber_al.txt
!vendor/bundled-origin/_dao_yuan_jing.txt

# 历史本源导出 (v9.1.2-dao 对照)
_origin_v912/**

# 测试 L1/L2
tests/**

# 运行时生成于 vendor · 不入包
vendor/bundled-origin/_sp_candidates.json
vendor/bundled-origin/_custom_sp.json
vendor/bundled-origin/_lastinject.json
vendor/bundled-origin/_origin_mode.txt
vendor/bundled-origin/_dao_81.txt

# 历史版本归档文档
V940_FINAL_REPORT.md
V941_REANCHOR_REPORT.md
V9*_REPORT.md
V9*_FINAL_REPORT.md
_v931_*.md
_v932_*.md
_v933_*.md
_v934_*.md

# 审视报告目录 (_* 匹顶层不匹目录内 · 此显排)
_审视/**
**/_审视/**

