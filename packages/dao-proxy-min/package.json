  "main": "./extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "dao-proxy-min runs in all workspaces"
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dao-container",
          "title": "道Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dao-container": [
        {
          "id": "dao.essence",
          "name": "本源观照",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "wam.originInvert",
        "title": "道Agent: 启 (invert · 道德经前置 · 彻删官方着相)",
        "category": "道Agent"
      },
      {
        "command": "wam.originPassthrough",
        "title": "官方Agent: 启 (passthrough · 锚归云 · 直连)",
        "category": "道Agent"
      },
      {
        "command": "dao.toggleMode",
        "title": "道Agent: 切换模式 (道 ⇄ 官方)",
        "category": "道Agent"
      },
      {
        "command": "dao.openPreview",
        "title": "道Agent: 浏览器观真 SP (/origin/preview)",
        "category": "道Agent"
      },
      {
        "command": "wam.verifyEndToEnd",
        "title": "全链路自检 (E2E)",
        "category": "道Agent"
      },
      {
        "command": "wam.selftest",
        "title": "闭环自检 (L1 + L2)",
        "category": "道Agent"
      },
      {
        "command": "dao.外接api.toggle",
        "title": "道Agent: 外接 api 开关 (印 124 · 14 provider · vscode.lm 注 · 默关)",
        "category": "道Agent"
      },
      {
        "command": "dao.term.exec",
        "title": "道Agent: 终端会话池 · exec (印 160 · 七层一招治 · 零第三方)",
        "category": "道Agent"
      },
      {
        "command": "dao.term.list",
        "title": "道Agent: 终端会话池 · list (列所有 sid · 终端池状)",
        "category": "道Agent"
      },
      {
        "command": "dao.term.close",
        "title": "道Agent: 终端会话池 · close (选 sid 关 · 释 shell 进程)",
        "category": "道Agent"
      }
    ],
    "configuration": {
      "title": "道Agent",
      "properties": {
        "dao.origin.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "源.js 反代端口 (0=自动 per-user FNV-1a hash · 8889..8988 · 多账号自然隔离). 非0则覆盖."
        },
        "dao.origin.defaultMode": {
          "type": "string",
          "default": "invert",
          "enum": [
            "invert",
            "passthrough"
          ],
          "enumDescriptions": [
            "invert — 道Agent · 道德经直为前置 + 彻删官方一切着相之名 (身份/风格/规训) · 工具本身全保不动",
            "passthrough — 官方Agent · 锚归云 · 直连"
          ],
          "description": "首激默模 (二态互斥 · 无off)"
        },
        "dao.origin.banner": {
          "type": "boolean",
          "default": false,
          "description": "启动时显道德经横幅 (默认 false · 不言之教)"
        },
        "dao.外接api.enabled": {
          "type": "boolean",
          "default": false,
          "description": "印 124 · 第一细药 · 外接 api 归一 · 启后: gateway :11635..11734 起 · vscode.lm 注 14 provider 之 N 模 · Cascade 选单见 'dao-*' · 与 4 BYOK 一视同仁. 需手编 ~/.codeium/dao-byok/配置.json 填 apiKey."
        }
      }
    }
  },
  "scripts": {
    "smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File _审视/_smoke.ps1",
    "strip-test": "node _审视/_v980_strip_test.js",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
