{
  "name": "dao-proxy-min",
  "displayName": "道Agent · 反者道之动 · 弱者道之用",
  "description": "v9.9.25 软编码归一·适所有用户·三平台主进程退 (二十八章「朴散为器·圣人用则为官长·夫大制无割」). 治本两味: ①抽 SELF_EXT_ID 自 package.json (publisher+name) · 软编码归一 · 适所有 fork/重命名/重发布; ②cmdPurge F 层主进程退三平台兜底 (Win=wmic+taskkill / Mac=ps+kill -9 / Linux=ps+kill -9) · 不再 Win-only · 适所有用户. 承 v9.9.24 (五层同治+主进程退) + v9.9.22 (三诉同治) + v9.9.21 (软编码 vendorDir). 反者道之动 · 损之又损至无为.",
  "version": "9.9.25",
  "publisher": "dao-agi",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhouyoukang/windsurf-assistant.git"
  },
  "homepage": "https://github.com/zhouyoukang/windsurf-assistant",
  "icon": "media/icon.png",
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "windsurf",
    "cascade",
    "system-prompt",
    "dao",
    "proxy",
    "minimal",
    "道德经",
    "反代",
    "essence"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "dao-proxy-min runs in all workspaces"
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dao-container",
          "title": "道Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dao-container": [
        {
          "id": "dao.essence",
          "name": "本源观照",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "wam.originInvert",
        "title": "道Agent: 启 (invert · 道德经前置 · 彻删官方着相)",
        "category": "道Agent"
      },
      {
        "command": "wam.originPassthrough",
        "title": "官方Agent: 启 (passthrough · 锚归云 · 直连)",
        "category": "道Agent"
      },
      {
        "command": "dao.toggleMode",
        "title": "道Agent: 切换模式 (道 ⇄ 官方)",
        "category": "道Agent"
      },
      {
        "command": "dao.openPreview",
        "title": "道Agent: 浏览器观真 SP (/origin/preview)",
        "category": "道Agent"
      },
      {
        "command": "wam.verifyEndToEnd",
        "title": "全链路自检 (E2E)",
        "category": "道Agent"
      },
      {
        "command": "wam.selftest",
        "title": "闭环自检 (L1 + L2)",
        "category": "道Agent"
      },
      {
        "command": "dao.purge",
        "title": "道Agent: 了事拂衣去 · 净卸 (停反代 · 清设置 · 卸插件 · 归本源)",
        "category": "道Agent"
      },
      {
        "command": "dao.外接api.toggle",
        "title": "道Agent: 外接 api 开关 (印 124 · 14 provider · vscode.lm 注 · 默关)",
        "category": "道Agent"
      }
    ],
    "configuration": {
      "title": "道Agent",
      "properties": {
        "dao.origin.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "源.js 反代端口 (0=自动 per-user FNV-1a hash · 8889..8988 · 多账号自然隔离). 非0则覆盖."
        },
        "dao.origin.defaultMode": {
          "type": "string",
          "default": "invert",
          "enum": [
            "invert",
            "passthrough"
          ],
          "enumDescriptions": [
            "invert — 道Agent · 道德经直为前置 + 彻删官方一切着相之名 (身份/风格/规训) · 工具本身全保不动",
            "passthrough — 官方Agent · 锚归云 · 直连"
          ],
          "description": "首激默模 (二态互斥 · 无off)"
        },
        "dao.origin.banner": {
          "type": "boolean",
          "default": false,
          "description": "启动时显道德经横幅 (默认 false · 不言之教)"
        },
        "dao.外接api.enabled": {
          "type": "boolean",
          "default": false,
          "description": "印 124 · 第一细药 · 外接 api 归一 · 启后: gateway :11635..11734 起 · vscode.lm 注 14 provider 之 N 模 · Cascade 选单见 'dao-*' · 与 4 BYOK 一视同仁. 需手编 ~/.codeium/dao-byok/配置.json 填 apiKey."
        }
      }
    }
  },
  "scripts": {
    "smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File _审视/_smoke.ps1",
    "strip-test": "node _审视/_v980_strip_test.js",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.6.0"
  }
}
