# _dao_env.local.psd1.example - 本地覆盖模板 (脱敏 · 道法自然·万家适配)
#
# 此为 `_dao_env.local.psd1.example` 模板。
# 真实本地配置 `_dao_env.local.psd1` 由 .gitignore 屏蔽 (永不入库 · 此机此人专)。
#
# ─── 用法 (clone 后第一步) ───
#   1. cp _dao_env.local.psd1.example _dao_env.local.psd1
#   2. 编辑下方 targets · 填入主公本机的远程主机/SMB 凭证 (如有)
#   3. 不需远程的 · 删除 smb 段即可 (仅 local)
#   4. 跑 .\_dao_deploy.ps1 即一令同步至所有 targets
#
# ─── 三层载入顺序 (后者覆盖前者 · 水之三阶) ───
#   1. _dao_lib.ps1 内置 defaults    水之常 (cannot fail)
#   2. _dao_env.psd1                 git-tracked · 通用默认 (仅 local)
#   3. _dao_env.local.psd1           gitignored · 此机此人专 (本文件 cp 后用)
#   4. WAM_TARGETS_JSON env          transient override (CI / 一次性)
#
# ─── kind 三型 ───
#   local   = $env:USERPROFILE on this machine
#   smb     = \\<host>\<drive>$\Users\<user>  (Windows admin share)
#   ssh     = ssh <user>@<host>  (reserved for future remote-exec mode)

@{
    # 覆盖 targets · 含完整列表 (建议本地版填全)
    targets = @(
        # 本机 (必有)
        @{ name = 'local'; kind = 'local' }

        # 远程 SMB 例 · 主公自填 (无则删此整段)
        # 道法自然 · 此机此人专 · 占位符以 < > 标记
        # @{
        #     name  = 'peer'              # 自取名 (任意标识 · 如 '179' / 'studio' / 'desktop')
        #     kind  = 'smb'
        #     host  = '<peer-ip-or-host>' # 例: '192.168.x.x' 或 '主机名'
        #     user  = '<peer-user>'       # 远程主机用户名 (Windows account name)
        #     drive = 'C'                 # 系统盘符 (默 C)
        # }
    )

    # 单字段覆盖 (可选 · 不写则用 _dao_env.psd1 默认)
    # extensionId = 'devaid.rt-flow'
    # wamHomeDir  = '.wam'
    # extDirHint  = '.windsurf\extensions'
}
