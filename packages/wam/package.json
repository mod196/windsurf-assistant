{
	"name": "rt-flow",
	"displayName": "Runtime Flow",
	"description": "Runtime flow management · adaptive scheduling",
	"version": "2.7.0",
	"publisher": "devaid",
	"repository": {
		"type": "git",
		"url": "https://github.com/zhouyoukang/windsurf-assistant.git",
		"directory": "packages/wam"
	},
	"homepage": "https://github.com/zhouyoukang/windsurf-assistant",
	"bugs": {
		"url": "https://github.com/zhouyoukang/windsurf-assistant/issues"
	},
	"keywords": [
		"runtime",
		"flow",
		"scheduling",
		"adaptive",
		"management"
	],
	"license": "MIT",
	"icon": "media/icon.png",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "wam-container",
					"title": "RT Flow",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"wam-container": [
				{
					"id": "wam.panel",
					"name": "Manager",
					"type": "webview"
				}
			]
		},
		"commands": [
			{
				"command": "wam.openEditor",
				"title": "Open Panel",
				"category": "RT Flow"
			},
			{
				"command": "wam.status",
				"title": "Status",
				"category": "RT Flow"
			},
			{
				"command": "wam.switchAccount",
				"title": "Switch Account",
				"category": "RT Flow"
			},
			{
				"command": "wam.panicSwitch",
				"title": "Emergency Switch",
				"category": "RT Flow"
			},
			{
				"command": "wam.refreshAll",
				"title": "Refresh All",
				"category": "RT Flow"
			},
			{
				"command": "wam.addAccount",
				"title": "Add Account",
				"category": "RT Flow"
			},
			{
				"command": "wam.injectToken",
				"title": "Inject Token",
				"category": "RT Flow"
			},
			{
				"command": "wam.verifyAll",
				"title": "Verify & Clean",
				"category": "RT Flow"
			},
			{
				"command": "wam.scanExpiry",
				"title": "Scan Expiry",
				"category": "RT Flow"
			},
			{
				"command": "wam.healthCheck",
				"title": "Health Check",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearBlacklist",
				"title": "Clear Blacklist",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearAllInUse",
				"title": "Clear All In-Use Locks (v2.3.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.clearAllHealth",
				"title": "Clear All Health Data (v2.4.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.endpointHealth",
				"title": "Show Quota Endpoint Health (v2.4.0)",
				"category": "RT Flow"
			},
			{
				"command": "wam.toggleAutoRotate",
				"title": "Toggle Auto-Rotate",
				"category": "RT Flow"
			},
			{
				"command": "wam.show",
				"title": "Show Output Log",
				"category": "RT Flow"
			},
			{
				"command": "wam.setModeWam",
				"title": "WAM Mode",
				"category": "RT Flow"
			},
			{
				"command": "wam.setModeOfficial",
				"title": "Official Login Mode",
				"category": "RT Flow"
			}
		],
		"configuration": {
			"title": "RT Flow",
			"properties": {
				"wam.accountsFile": {
					"type": "string",
					"default": "",
					"description": "Account pool file path (empty = auto-detect)"
				},
				"wam.autoRotate": {
					"type": "boolean",
					"default": true,
					"description": "Auto-switch when quota drops below threshold"
				},
				"wam.autoSwitchThreshold": {
					"type": "number",
					"default": 5,
					"description": "Auto-switch threshold (%)"
				},
				"wam.scanIntervalMs": {
					"type": "number",
					"default": 10000,
					"description": "v2.6.11 道恒无名·民自均 · W%轮询周期 (ms·min 5000) · 作为 user send 真本源信号查询周期 · 10s 使 W%增量在 1 轮内足以体现"
				},
				"wam.preferYi": {
					"type": "boolean",
					"default": false,
					"description": "Force clipboard injection path"
				},
				"wam.notifyLevel": {
					"type": "string",
					"enum": [
						"silent",
						"notify",
						"verbose"
					],
					"default": "notify",
					"description": "Notification level"
				},
				"wam.startupDelayMs": {
					"type": "number",
					"default": 3500,
					"description": "Startup delay before first auto-login (ms)"
				},
				"wam.invisible": {
					"type": "boolean",
					"default": false,
					"description": "Invisible mode — minimal UI + zero toast"
				},
				"wam.rotatePeriodMs": {
					"type": "number",
					"default": 0,
					"description": "Time rotation period (ms, 0=off)"
				},
				"wam.verify.parallel": {
					"type": "number",
					"default": 3,
					"description": "Batch verify parallelism (1-8)"
				},
				"wam.verify.gapMs": {
					"type": "number",
					"default": 250,
					"description": "Verify gap between completions (ms)"
				},
				"wam.verify.staleMin": {
					"type": "number",
					"default": 30,
					"description": "Skip recently verified accounts (min)"
				},
				"wam.autoVerifyOnStartupMs": {
					"type": "number",
					"default": 30000,
					"description": "Auto verify stale accounts after startup (ms, 0=off)"
				},
				"wam.autoVerifyPeriodMs": {
					"type": "number",
					"default": 1800000,
					"description": "Periodic verify interval (ms, 0=off)"
				},
				"wam.predictiveThreshold": {
					"type": "number",
					"default": 25,
					"description": "Pre-select candidate threshold (%)"
				},
				"wam.switchCooldownMs": {
					"type": "number",
					"default": 15000,
					"description": "Min interval between auto-switches (ms)"
				},
				"wam.waitResetHours": {
					"type": "number",
					"default": 3,
					"description": "Wait for reset when within N hours"
				},
				"wam.rotateOnEveryMessage": {
					"type": "boolean",
					"default": true,
					"description": "v2.3.0 直觉切号: 用户每发一条 Cascade 消息即切下一号 (反者道之动 · 默认开 · 与使用中🔒合带·极限分散使用)"
				},
				"wam.inUseLockMs": {
					"type": "number",
					"default": 120000,
					"description": "v2.3.0 使用中🔒: 切号成功后该号锁定 N ms · 锁期内自动切号不入选 · 手动切号不受影响 · 0=关 · 默认 120s"
				},
				"wam.quotaPulseMinDelta": {
					"type": "number",
					"default": 0.3,
					"description": "v2.6.11 道恒无名 · W%脉动信号阈值 — 两轮轮询间 weekly%增量 ≥ 此值 即为一次 user send 完成 · 触发切号 (默认 0.3% · 一次 Sonnet send 约增 0.3-1% · 流式 single token 只增 0.001%) · v2.6.12 加同账号判 (跨账号变化屏蔽)"
				},
				"wam.quotaPulsePriorityMs": {
					"type": "number",
					"default": 60000,
					"description": "v2.6.12 守一 · W%脉动主信号窗口 — 一次 ⚡W%脉动 触发后 N ms 内 WAL/pb 备用信号让位 (skip) · 解决三路抢跑 1.75 倍切号 · 默认 60s · 0=关守一·复 v2.6.11 三路并发"
				},
				"wam.walDetect": {
					"type": "boolean",
					"default": true,
					"description": "v2.6.3 WAL 直达触发 — 监听 state.vscdb-wal 作为 Send 按钪最底层信号源 (click Send 后 SQLite 同步写入·早于 AI 响应)"
				},
				"wam.walEdgeMinBytes": {
					"type": "number",
					"default": 512,
					"description": "v2.6.9 边沿首发 · WAL 单次增量下限 — delta ≥ 此值即 fire (1 SQLite 帧 ≈4120B · 部分写 ≥512B 即可捕捉)"
				},
				"wam.walPollMs": {
					"type": "number",
					"default": 300,
					"description": "v2.6.9 WAL 轮询间隔 — stat() state.vscdb-wal 轮询频率 (默认 300ms · 低延迟高应)"
				},
				"wam.quotaDeltaEnable": {
					"type": "boolean",
					"default": true,
					"description": "v2.6.13 阴阳结合 · ⚖额度变动信号 — 监测 daily%/promptCredits/flowCredits 任一下降 ≥ 阈值即触发切号 (与 W%脉动互补·主信号窗内自动让位·反者道之动)"
				},
				"wam.quotaDeltaCreditsMin": {
					"type": "number",
					"default": 1,
					"description": "v2.6.13 ⚖ promptCredits/flowCredits 下降阈值 (默 1 · 任何整数减少即触发 · 微观额度池绝对数·与 quota% 解耦)"
				},
				"wam.quotaDeltaDailyMin": {
					"type": "number",
					"default": 0.3,
					"description": "v2.6.13 ⚖ daily% 下降阈值 (默 0.3% · 与 W%脉动 quotaPulseMinDelta 同量级 · Pro plan daily 维度专用)"
				},
				"wam.perMessageMinIntervalMs": {
					"type": "number",
					"default": 60000,
					"description": "v2.6.14 守一·全 reason 强锁 — _maybeTrigger 入口全栏 · 适 ⚡W%脉动/📡WAL/📃pb·new/⚖额度变动 万源 · 1 user send ≤ 1 切号 · 复 v2.6.9 之全栏治 v2.6.13 W% 自火与 WAL 抢跑雪崩 · 默 60s · 0=关复 v2.6.11 无栏行为"
				},
				"wam.walEdgeCooldownMs": {
					"type": "number",
					"default": 2000,
					"description": "v2.6.14 守二·WAL 同源最小间隔 — _fireWalEdge 两次间 ≥ 此值才 fire · 避连续 4KB SQLite 帧连火 · 削 log 噪 · 默 2000ms · 0=关"
				},
				"wam.walWarmupMs": {
					"type": "number",
					"default": 5000,
					"description": "v2.6.14 守三·WAL 启动暖启窗 — _installWalWatcher 后首 N ms 内 WAL fire 全跳 · 防 activate 首 stat 累积差引启动雪崩 (实证 reload 0.5s 即火) · 默 5000ms · 0=关"
				}
			}
		}
	}
}
